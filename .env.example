# Copy this file to llm_backend/.env and fill in your own values.
# Never commit llm_backend/.env to GitHub.

# Online LLM service. Moonshot/Kimi and DeepSeek both use OpenAI-compatible APIs.
DEEPSEEK_API_KEY=your_llm_api_key
DEEPSEEK_BASE_URL=https://api.moonshot.cn/v1
DEEPSEEK_MODEL=moonshot-v1-8k

# Vision model for image understanding.
VISION_API_KEY=your_vision_api_key
VISION_BASE_URL=https://api.moonshot.cn/v1
VISION_MODEL=moonshot-v1-8k-vision-preview

# Service selection: deepseek or ollama.
CHAT_SERVICE=deepseek
REASON_SERVICE=deepseek
AGENT_SERVICE=deepseek

# Ollama local models. Required only when using local models or semantic cache embeddings.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_REASON_MODEL=deepseek-r1:7b
OLLAMA_AGENT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=bge-m3

# Optional online search via SerpAPI.
SERPAPI_KEY=your_serpapi_key
SEARCH_RESULT_COUNT=10

# MySQL database.
DB_HOST=localhost
DB_PORT=3306
DB_USER=shopcare_user
DB_PASSWORD=your_mysql_password
DB_NAME=shopcare_agent

# Neo4j knowledge graph. Required for Text2Cypher / graph tools.
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# Redis semantic cache. Required for Redis cache acceleration.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.90

# GraphRAG project settings.
GRAPHRAG_PROJECT_DIR=llm_backend/app/graphrag
GRAPHRAG_DATA_DIR=data
GRAPHRAG_QUERY_TYPE=local
GRAPHRAG_RESPONSE_TYPE=text
GRAPHRAG_COMMUNITY_LEVEL=3
GRAPHRAG_DYNAMIC_COMMUNITY=false

# FastAPI/JWT secret. Change in production.
SECRET_KEY=change_me_in_production